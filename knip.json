{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreDependencies": ["@fontsource/inter", "@fontsource/jetbrains-mono", "@testing-library/react", "tailwindcss"],
  "ignore": ["src/test/**"],
  "rules": {
    "unlisted": "error",
    "files": "error",
    "exports": "warn",
    "types": "warn"
  }
}
